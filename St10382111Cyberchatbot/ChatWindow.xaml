<Window x:Class="St10382111Cyberchatbot.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyrex Chat"
        Height="700" Width="950"
        MinHeight="520" MinWidth="700"
        Background="#0A0E1A"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- ASCII header -->
            <RowDefinition Height="*"/>      <!-- Chat bubbles -->
            <RowDefinition Height="Auto"/>   <!-- Input bar -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════
             HEADER  –  ASCII art + status panel
             (replaces AsciiPage.Show() from Part 1)
        ════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#0D1B2A"
                BorderBrush="#00FF88"
                BorderThickness="0,0,0,2"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ASCII Logo (from AsciiPage) -->
                <StackPanel Grid.Column="0">
                    <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               Foreground="#00FF88"
                               Text="  ___ _   _ ____  _______  __"/>
                    <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               Foreground="#00FF88"
                               Text=" / __| | | | __ \| ____\ \/ /"/>
                    <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               Foreground="#00D4FF"
                               Text="| |  | |_| |  __/|  _|  >  &lt; "/>
                    <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               Foreground="#00D4FF"
                               Text="| |__|  _  | |   | |___/ . \ "/>
                    <TextBlock FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                               Foreground="#00FF88"
                               Text=" \___|_| |_|_|   |_____/_/\_\"/>
                    <TextBlock FontFamily="Consolas" FontSize="9"
                               Foreground="#3A5068" Margin="0,3,0,0"
                               Text="  C Y B E R S E C U R I T Y   A W A R E N E S S   C H A T B O T"/>
                </StackPanel>

                <!-- Right panel: online dot + user name + sentiment -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Background="#0A1A2A" CornerRadius="5" Padding="10,5"
                            BorderBrush="#1E3A5F" BorderThickness="1" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#00FF88" Margin="0,0,5,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="ONLINE" Foreground="#00FF88"
                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="TxtUserName"
                               Text="User: Guest"
                               Foreground="#607B8B" FontFamily="Consolas" FontSize="11"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="TxtSentiment"
                               Text="Mood: Neutral"
                               Foreground="#607B8B" FontFamily="Consolas" FontSize="10"
                               HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             CHAT AREA  –  scrollable bubble list
        ════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="10,8,10,0"
                Background="#111827"
                CornerRadius="8"
                BorderBrush="#1E3A5F"
                BorderThickness="1">
            <ScrollViewer x:Name="ChatScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="4">
                <StackPanel x:Name="ChatPanel" Margin="6,6,6,4"/>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════
             INPUT BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="10,7,10,5"
                Background="#0D1B2A"
                CornerRadius="8"
                BorderBrush="#00FF88"
                BorderThickness="1"
                Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtInput"
                         Grid.Column="0"
                         Background="Transparent"
                         Foreground="#E2E8F0"
                         CaretBrush="#00FF88"
                         BorderThickness="0"
                         FontSize="14"
                         VerticalAlignment="Center"
                         Padding="4,6"
                         KeyDown="TxtInput_KeyDown"/>

                <!-- Voice toggle -->
                <Button x:Name="BtnVoice"
                        Grid.Column="1"
                        Content="🔊"
                        ToolTip="Toggle voice"
                        Width="36" Height="36" Margin="6,0,4,0"
                        Background="#162030"
                        Foreground="#00FF88"
                        BorderBrush="#1E3A5F" BorderThickness="1"
                        FontSize="15" Cursor="Hand"
                        Click="BtnVoice_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Send button -->
                <Button x:Name="BtnSend"
                        Grid.Column="2"
                        Content="SEND  ➤"
                        Width="88" Height="36"
                        Background="#00843D"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold" FontSize="12"
                        Cursor="Hand"
                        Click="BtnSend_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════
             STATUS BAR
        ════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#080F1A" Padding="12,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus"
                           Grid.Column="0"
                           Text="Ready  ask me anything about cybersecurity."
                           Foreground="#3A5068" FontFamily="Consolas" FontSize="11"/>
                <TextBlock Grid.Column="1"
                           Text="Cyrex  |  St10382111"
                           Foreground="#1E3A5F" FontFamily="Consolas" FontSize="10"/>
            </Grid>
        </Border>
    </Grid>
</Window>
